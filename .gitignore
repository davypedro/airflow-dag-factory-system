# ── Ambiente virtual ───────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/

# ── Variáveis de ambiente e segredos ──────────────────────
.env
*.key
*.pem
*.p12
*.pfx
secrets/

# ── Airflow ────────────────────────────────────────────────
logs/
airflow.db
airflow.cfg
webserver_config.py
standalone_admin_password.txt
.airflow/

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
*.so
*.pyd

# ── Testes e cobertura ─────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.coveragerc

# ── Type checking ──────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── Linter ────────────────────────────────────────────────
.ruff_cache/

# ── IDEs ──────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.suo
*.user
.vs/
*.iml

# ── Sistema operacional ────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Docker ────────────────────────────────────────────────
